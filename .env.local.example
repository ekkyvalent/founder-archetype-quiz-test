# ─── HubSpot ───────────────────────────────────────────────
# Found in HubSpot → Settings → Integrations → API Key
HUBSPOT_PORTAL_ID=your_portal_id_here
HUBSPOT_FORM_ID=your_form_guid_here

# ─── Customer.io ────────────────────────────────────────────
# Found in Customer.io → Settings → API Credentials
CIO_SITE_ID=your_site_id_here
CIO_API_KEY=your_api_key_here

# ─── App ────────────────────────────────────────────────────
# The public base URL of this app (used for OG image generation)
NEXT_PUBLIC_BASE_URL=https://aspireapp.com/founder-archetype-quiz
